<Window x:Class="ConstructionMaterial.Views.AddMaterialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Material"
        Height="330" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource MainWindowBrush}">

    <Window.Resources>
        <Style TargetType="TextBox">
            <EventSetter Event="TextChanged" Handler="TextBox_TextChanged"/>
        </Style>
    </Window.Resources>

    <Border Margin="20" Style="{StaticResource ModernBorder}">
        <Grid Margin="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Category:"
                       Style="{StaticResource ModernText}"
                       Grid.Row="0"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="CategoryBox"
                      Grid.Row="0"
                      Grid.Column="1"
                      Margin="5"
                      ItemsSource="{Binding MaterialTypes}"
                      SelectedIndex="0"/>

            <TextBlock Text="Material Name:"
                       Style="{StaticResource ModernText}"
                       Grid.Row="1"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="MaterialNameTxt"
                     Grid.Row="1"
                     Grid.Column="1"
                     Margin="5"/>

            <TextBlock Text="Unit:"
                       Style="{StaticResource ModernText}"
                       Grid.Row="2"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="UnitTxt"
                     Grid.Row="2"
                     Grid.Column="1"
                     Margin="5"/>

            <TextBlock Text="Unit Price:"
                       Style="{StaticResource ModernText}"
                       Grid.Row="3"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="UnitPriceTxt"
                     Grid.Row="3"
                     Grid.Column="1"
                     Margin="5"/>

            <StackPanel Grid.Row="4"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0">

                <Button Content="Cancel"
                        Width="100"
                        Margin="10,0"
                        Style="{StaticResource ModernButton}"
                        Click="Cancel_Click"/>

                <Button Content="Save"
                        x:Name="BtnSave"
                        Width="100"
                        Margin="10,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="Save_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>