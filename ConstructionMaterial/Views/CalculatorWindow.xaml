<Window x:Class="ConstructionMaterial.Views.CalculatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Material Calculator" 
        Height="550" 
        Width="480"
        xmlns:local="clr-namespace:ConstructionMaterial.Models.Enum"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Window.Resources>



    </Window.Resources>

    <Border Margin="20" Style="{StaticResource ModernBorder}">
        <Grid Margin="15">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem Header="Concrete" Width="100">
                    <Grid Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Element Type:" 
                                   Grid.Row="0" 
                                   Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Row="0" 
                                  Grid.Column="1" 
                                  Height="32" 
                                  Margin="0,5"
                                  ItemsSource="{Binding ElementTypes}"
                                  SelectedIndex="0"/>
                        
                        <TextBlock Text="Material Name:" 
                                   Grid.Row="1" 
                                   Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Row="1"
                                  x:Name="MaterialComboBox"
                                  Grid.Column="1" 
                                  Height="32" 
                                  Margin="0,5"
                                  ItemsSource="{Binding MaterialNames}"
                                  DisplayMemberPath="Name"
                                  SelectedIndex="0"/>

                        <TextBlock Text="Length (m):" 
                                   Grid.Row="2" 
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="2" 
                                 Grid.Column="1"
                                 x:Name="LengthTxt"
                                 Style="{StaticResource ModernBox}"/>

                        <TextBlock Text="Width (m):" 
                                   Grid.Row="3" 
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="3" 
                                 Grid.Column="1"
                                 x:Name="WidthTxt"
                                 Style="{StaticResource ModernBox}"/>

                        <TextBlock Text="Depth (m):" 
                                   Grid.Row="4" 
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="4" 
                                 Grid.Column="1"
                                 x:Name="DepthTxt"
                                 Style="{StaticResource ModernBox}"
                                 />

                        <TextBlock Text="Quantity:" 
                                   Grid.Row="5" 
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="5" 
                                 Grid.Column="1"
                                 x:Name="QuantityTxt"
                                Style="{StaticResource ModernBox}"
                                 />

                        <StackPanel Grid.Row="6" 
                                    Grid.ColumnSpan="2" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right" 
                                    Margin="0,15">
                            <Button Content="Calculate" 
                                    Name="CalculateButton"
                                    Style="{StaticResource ModernButton}"
                                    Click="CalculateButton_Click"/>
                            <Button Content="Save Data" 
                                    Name="SaveButton"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="SaveButton_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Row="7" 
                                    Grid.ColumnSpan="2" 
                                    Background="{StaticResource MainTextBrush}"
                                    Margin="20">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Total Order Volume:" 
                                           VerticalAlignment="Center" 
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="TotalOrderValue" 
                                           Text="0.00 m³" 
                                           Margin="10,0" 
                                           Foreground="#059669" 
                                           FontWeight="Bold" 
                                           FontSize="20"/>
                            </StackPanel>
                            <TextBlock Text="Note: The total order volume is calculated assuming 10% waste factor."
                                       FontSize="10"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Steel" Width="100"/>
                <TabItem Header="Paint" Width="100"/>
            </TabControl>
        </Grid>
    </Border>
</Window>