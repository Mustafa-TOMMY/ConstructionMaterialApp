<ui:FluentWindow
    x:Class="ConstructionMaterial.Views.CalculatorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ConstructionMaterial.UserControls"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Material Calculator"
    Width="500"
    Height="606"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Fluent TitleBar  -->
        <ui:TitleBar Title="Material Calculator" Grid.Row="0" />

        <Border
            Grid.Row="1"
            Margin="20"
            Style="{StaticResource ModernBorder}">
            <Grid Margin="15">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabItem Width="100" Header="Concrete">
                        <controls:ConcreteCalculator x:Name="ConcreteCalculatorControl" />
                    </TabItem>

                    <TabItem Width="100" Header="Steel">
                        <controls:SteelCalculator x:Name="SteelCalculatorControl" />
                    </TabItem>

                    <TabItem Width="100" Header="Paint">
                        <controls:PaintCalculator x:Name="PaintCalculatorControl" />
                    </TabItem>

                    <TabItem Width="100" Header="Tiles">
                        <controls:TilesCalculator x:Name="TilesCalculatorControl" />
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>