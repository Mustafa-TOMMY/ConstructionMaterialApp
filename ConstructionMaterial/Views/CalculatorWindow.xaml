<Window x:Class="ConstructionMaterial.Views.CalculatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Material Calculator" 
        Height="550" 
        Width="500"
        xmlns:local="clr-namespace:ConstructionMaterial.Models.Enum"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:controls="clr-namespace:ConstructionMaterial.UserControls"
        WindowStartupLocation="CenterScreen" 
        Background="{StaticResource MainTextBrush}">

    <Window.Resources>



    </Window.Resources>

    <Border Margin="20" Style="{StaticResource ModernBorder}">
        <Grid Margin="15">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem Header="Concrete" Width="100">
                    <Grid Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Element Type:" 
                                   Grid.Row="0" 
                                   Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Row="0" 
                                  x:Name="ElementTypeComboBox"
                                  Grid.Column="1" 
                                  Height="32" 
                                  Margin="0,5"
                                  ItemsSource="{Binding ElementTypes}"
                                  SelectedIndex="0"/>

                        <TextBlock Text="Material Name:" 
                                   Grid.Row="1" 
                                   Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Row="1"
                                  x:Name="MaterialComboBox"
                                  Grid.Column="1" 
                                  Height="32" 
                                  Margin="0,5"
                                  ItemsSource="{Binding MaterialNames}"
                                  DisplayMemberPath="Name"
                                  SelectedIndex="0"/>

                        <TextBlock Text="Length (m):" 
                                   Grid.Row="2" 
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="2" 
                                 Grid.Column="1"
                                 x:Name="LengthTxt"
                                 Style="{StaticResource ModernBox}"/>

                        <TextBlock Text="Width (m):" 
                                   Grid.Row="3" 
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="3" 
                                 Grid.Column="1"
                                 x:Name="WidthTxt"
                                 Style="{StaticResource ModernBox}"/>

                        <TextBlock Text="Depth (m):" 
                                   Grid.Row="4" 
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="4" 
                                 Grid.Column="1"
                                 x:Name="DepthTxt"
                                 Style="{StaticResource ModernBox}"
                                 />

                        <TextBlock Text="Quantity:" 
                                   Grid.Row="5" 
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="5" 
                                 Grid.Column="1"
                                 x:Name="QuantityTxt"
                                Style="{StaticResource ModernBox}"/>

                        <StackPanel Grid.Row="6" 
                                    Grid.Column="2" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right" 
                                    Margin="0,15">
                            <Button Content="Calculate" 
                                    Name="ConcreteCalculateButton"
                                    Style="{StaticResource ModernButton}"
                                    Click="CalculateButton_Click"/>
                            <Button Content="Create Order" 
                                    Name="SaveButton"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="SaveButton_Click"/>
                        </StackPanel>

                        <controls:CalculationOutput Grid.Row="7" 
                                                    Grid.ColumnSpan="2" 
                                                    x:Name="OutputControl"
                                                    OutputValue="0.0 m³"
                                                    OutputLabel="Total Order Value:"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Steel" Width="100">
                    <Grid Margin="0,20,0,0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Bar Diameter:"
                                    Grid.Row="0"
                                    Style="{StaticResource FieldLabel}"/>

                        <ComboBox Grid.Row="0"
                                    Grid.Column="1"
                                    x:Name="BarDiameterComboBox"
                                    Height="32"
                                    Margin="0,5"
                                    ItemsSource="{Binding BarDiameters}"
                                    SelectedIndex="0"/>

                        <TextBlock Text="Bar Length (m):"
                                    Grid.Row="1"
                                    Style="{StaticResource FieldLabel}"/>

                        <TextBox Grid.Row="1"
                                Grid.Column="1"
                                x:Name="BarLengthTxt"
                                Style="{StaticResource ModernBox}"/>

                        <TextBlock Text="Number Of Bars:"
                                    Grid.Row="2"
                                    Style="{StaticResource FieldLabel}"/>

                        <TextBox Grid.Row="2"
                                Grid.Column="1"
                                x:Name="NoOfBarsTxt"
                                Style="{StaticResource ModernBox}"/>
                        
                        <StackPanel Grid.Row="3"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,15">

                            <Button Content="Calculate"
                                    Name="SteelCalculateButton"
                                    Style="{StaticResource ModernButton}"
                                    Click="CalculateButton_Click"/>

                            <Button Content="Create Order"
                                    Name="SaveButton2"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="SaveButton_Click"/>
                        </StackPanel>

                        <controls:CalculationOutput Grid.Row="7" 
                                                    Grid.ColumnSpan="2" 
                                                    x:Name="OutputSteelControl"
                                                    VerticalAlignment="Bottom"
                                                    OutputValue="0.0 m³"
                                                    OutputLabel="Total Order Value:"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Paint" Width="100">
                    <Grid Margin="0,20,0,0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Surface Type -->
                        <TextBlock Text="Surface Type:"
                                    Grid.Row="0"
                                    Style="{StaticResource FieldLabel}"/>

                        <ComboBox Grid.Row="0"
                                x:Name="SurfaceTypeComboBox"
                                Grid.Column="1"
                                ItemsSource="{Binding SurfaceTypes}"
                                Height="32"
                                Margin="0,5"
                                SelectedIndex="0"/>


                        <!-- Surface Area -->
                        <TextBlock Text="Surface Area (m²):"
                                    Grid.Row="1"
                                    Style="{StaticResource FieldLabel}"/>

                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 x:Name="SurfaceAreaTxt"
                                 Style="{StaticResource ModernBox}"/>

                        <!-- Number Of Coats -->
                        <TextBlock Text="Number Of Coats:"
                                    Grid.Row="2"
                                    Style="{StaticResource FieldLabel}"/>

                        <TextBox Grid.Row="2"
                                Grid.Column="1"
                                Height="32"
                                 x:Name="NoOfCoatsTxt"
                                Margin="0,5"/>

                        <!-- Coverage Rate -->
                        <TextBlock Text="Coverage Rate(m²/L):"
                                    Grid.Row="3"
                                    Style="{StaticResource FieldLabel}"/>

                        <TextBox Grid.Row="3"
                                Grid.Column="1"
                                x:Name="CoverageRateTxt"
                                Style="{StaticResource ModernBox}"/>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="4"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,15">

                            <Button Content="Calculate"
                                    Name="PaintCalculateButton"
                                    Style="{StaticResource ModernButton}"
                                    Click="CalculateButton_Click"/>

                            <Button Content="Create Order"
                                    Name="SaveButton3"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="SaveButton_Click"/>
                        </StackPanel>

                        <controls:CalculationOutput Grid.Row="7" 
                                                    Grid.ColumnSpan="2" 
                                                    x:Name="OutputPaintControl"
                                                    VerticalAlignment="Bottom"
                                                    OutputValue="0.0 m³"
                                                    OutputLabel="Total Order Value:"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Tiles" Width="100">
                    <Grid Margin="0,20,0,0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Room Length -->
                        <TextBlock Text="Room Length (m):"
                                    Grid.Row="0"
                                    Style="{StaticResource FieldLabel}"/>

                        <TextBox Grid.Row="0"
                                Grid.Column="1"
                                x:Name="RoomLengthTxt"
                                Style="{StaticResource ModernBox}"/>

                        <!-- Room Width -->
                        <TextBlock Text="Room Width (m):"
                                    Grid.Row="1"
                                    Style="{StaticResource FieldLabel}"/>

                        <TextBox Grid.Row="1"
                                Grid.Column="1"
                                x:Name="RoomWidthTxt"
                                Style="{StaticResource ModernBox}"/>

                        <!-- Tile Size -->
                        <TextBlock Text="Tile Size:"
                                    Grid.Row="2"
                                    Style="{StaticResource FieldLabel}"/>

                        <ComboBox Grid.Row="2"
                                x:Name="TileSizeComboBox"
                                Grid.Column="1"
                                Height="32"
                                Margin="0,5"
                                ItemsSource="{Binding TileSizes}"
                                DisplayMemberPath="Size"
                                SelectedIndex="1"/>

                        <!-- Waste -->
                        <TextBlock Text="Waste Percentage (%):"
                                Grid.Row="3"
                                Style="{StaticResource FieldLabel}"/>

                        <TextBox Grid.Row="3"
                                Grid.Column="1"
                                x:Name="WasteTxt"
                                Text="10"
                                Style="{StaticResource ModernBox}"/>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="4"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,15">

                            <Button Content="Calculate"
                                    Name="TilesCalculateButton"
                                    Style="{StaticResource ModernButton}"
                                    Click="CalculateButton_Click"/>

                            <Button Content="Create Order"
                                    Name="SaveButton4"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="SaveButton_Click"/>

                        </StackPanel>
                        <controls:CalculationOutput Grid.Row="7" 
                                                    Grid.ColumnSpan="2" 
                                                    x:Name="OutputTilesControl"
                                                    VerticalAlignment="Bottom"
                                                    OutputValue="0.0 m³"
                                                    OutputLabel="Total Order Value:"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>