<Window x:Class="ConstructionMaterial.Views.CalculatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Material Calculator" 
        Height="550" 
        Width="500"
        ResizeMode="NoResize"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:controls="clr-namespace:ConstructionMaterial.UserControls"
        WindowStartupLocation="CenterScreen" 
        Background="{StaticResource MainWindowBrush}">
    
    <Border Margin="20" Style="{StaticResource ModernBorder}">
        <Grid Margin="15">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem Header="Concrete" Width="100">
                    <controls:ConcreteCalculator x:Name="ConcreteCalculatorControl"/>
                </TabItem>

                <TabItem Header="Steel" Width="100">
                    <controls:SteelCalculator x:Name="SteelCalculatorControl"/>
                </TabItem>

                <TabItem Header="Paint" Width="100">
                    <controls:PaintCalculator x:Name="PaintCalculatorControl"/>
                </TabItem>

                <TabItem Header="Tiles" Width="100">
                    <controls:TilesCalculator x:Name="TilesCalculatorControl"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>