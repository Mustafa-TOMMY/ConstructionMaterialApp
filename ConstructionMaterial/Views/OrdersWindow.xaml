<Window x:Class="ConstructionMaterial.Views.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:ConstructionMaterial.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewmodels:OrderViewModel, IsDesignTimeCreatable=False}"
        mc:Ignorable="d"
        Title="Order Management System" 
        Height="600" 
        Width="940"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource MainWindowBrush}">
    <Grid>
        <Border Margin="20" Style="{StaticResource ModernBorder}">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource FontAwesome}"
                        FontSize="24"
                        Foreground="{StaticResource MainBrush}"
                        Text="&#xf0d1;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{StaticResource IconsBrush}"
                        Text="Order History &amp; Tracking" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Margin="0,0,0,15"
                    Padding="15,5"
                    Background="#F8FAFC"
                    CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Category" Style="{StaticResource FieldLabel}" FontSize="12" Margin="0,0,0,2"/>
                            <ComboBox Width="150"
                                      Height="32"
                                      ItemsSource="{Binding SearchOptions}"
                                      SelectedItem="{Binding SelectedCategory, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Material" Style="{StaticResource FieldLabel}" FontSize="12" Margin="0,0,0,2"/>
                            <ComboBox Width="120" 
                                      ItemsSource="{Binding MaterialForSearch}"
                                      SelectedItem="{Binding SelectedMaterial, UpdateSourceTrigger=PropertyChanged}"
                                      Height="32"/>

                        </StackPanel>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Status" Style="{StaticResource FieldLabel}" 
                                       FontSize="12" Margin="0,0,0,2"/>
                            <ComboBox Width="120"
                                      Height="32"
                                      ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding SelectedStatus, UpdateSourceTrigger=PropertyChanged}"/>

                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="From:" Style="{StaticResource FieldLabel}" 
                                       FontSize="12" Margin="0,0,0,2"/>
                            <DatePicker Width="120" 
                                        Height="32" 
                                        SelectedDate="{Binding FromDate, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="To:" Style="{StaticResource FieldLabel}" 
                                       FontSize="12" Margin="0,0,0,2"/>
                            <DatePicker Width="120" 
                                        Height="32"
                                        SelectedDate="{Binding ToDate, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <Button Command="{Binding ResetCommand}" 
                                Style="{StaticResource ModernButton}" 
                                Width="100" 
                                Height="32"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontAwesome}"
                                    FontSize="14"
                                    Foreground="{StaticResource IconsBrush}"
                                    Text="&#xf2f9;" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Reset" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="2"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          ItemsSource="{Binding OrdersCollection}"
                          SelectedItem="{Binding SelectedOrder, UpdateSourceTrigger=PropertyChanged}"
                          Background="Transparent"
                          RowHeight="35">

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding OrderNumber}"
                            Header="Order #" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Date, StringFormat=\{0:dd/MM/yyyy\}}"
                            Header="Date" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding MaterialName}"
                            Header="Material Name" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding ElementType}"
                            Header="Element Type" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Category}"
                            Header="Category" />
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding Quantity}"
                            Header="Qty" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding UnitPrice, StringFormat=\{0:N2\}}"
                            Header="Price" />

                        <DataGridTextColumn
                            Width="130"
                            Binding="{Binding Total, StringFormat=\{0:N2\}}"
                            ElementStyle="{StaticResource ValueText}"
                            Header="Total Amount" />

                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Status}"
                            Header="Status" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border
                    Grid.Row="3"
                    Padding="0,10,0,0"
                    Style="{StaticResource ModernBorder}">
                    <DockPanel LastChildFill="False">

                        <StackPanel
                            VerticalAlignment="Center"
                            DockPanel.Dock="Left"
                            Orientation="Horizontal">

                            <TextBlock Text="Items:" Style="{StaticResource FieldLabel}" Foreground="Gray" FontSize="11"/>
                            <TextBlock Text="{Binding ItemsCount}" FontWeight="Bold" Margin="0,0,15,0"/>

                            <TextBlock Text="Total Cost:" Style="{StaticResource FieldLabel}" Foreground="Gray" FontSize="11"/>
                            <TextBlock Text="{Binding TotalCost, StringFormat=\{0:N2\} EGP}" FontWeight="Bold" Foreground="{StaticResource BtnSecondeBrush}" Margin="0,0,15,0"/>

                            <TextBlock Text="Pending:" Style="{StaticResource FieldLabel}" Foreground="Gray" FontSize="11"/>
                            <TextBlock Text="{Binding PendingCount}" FontWeight="Bold" Foreground="OrangeRed"/>

                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Command="{Binding MarkDeliveredCommand}" 
                                    Style="{StaticResource SecondaryButton}" 
                                    Width="160" 
                                    Height="38"
                                    Margin="5,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontAwesome}"
                                        FontSize="16"
                                        Foreground="{StaticResource IconsBrush}"
                                        Text="&#xf058;" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="Black"
                                        Text="Mark Delivered" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ExportCommand}" 
                                    Style="{StaticResource ModernButton}" 
                                    Width="120" 
                                    Height="38"
                                    Margin="5,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontAwesome}"
                                        FontSize="16"
                                        Foreground="{StaticResource IconsBrush}"
                                        Text="&#xf56e;" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Export" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding DeleteCommand}" 
                                    Style="{StaticResource DangerButton}" 
                                    Width="110" 
                                    Height="38"
                                    Margin="5,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontAwesome}"
                                        FontSize="16"
                                        Foreground="{StaticResource IconsBrush}"
                                        Text="&#xf2ed;" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Delete" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>