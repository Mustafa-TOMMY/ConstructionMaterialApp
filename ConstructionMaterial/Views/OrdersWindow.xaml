<Window
    x:Class="ConstructionMaterial.Views.OrdersWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Order Management System"
    Width="940"
    Height="600"
    Background="{StaticResource MainWindowBrush}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Border Margin="20" Style="{StaticResource ModernBorder}">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource FontAwesome}"
                        FontSize="24"
                        Foreground="{StaticResource MainBrush}"
                        Text="&#xf0d1;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{StaticResource IconsBrush}"
                        Text="Order History &amp; Tracking" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Margin="0,0,0,15"
                    Padding="15,5"
                    Background="#F8FAFC"
                    CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock
                                Margin="0,0,0,2"
                                FontSize="12"
                                Style="{StaticResource FieldLabel}"
                                Text="Category" />
                            <ComboBox
                                x:Name="CategorySearchComboBox"
                                Width="150"
                                Height="32"
                                ItemsSource="{Binding SearchOptions}"
                                SelectionChanged="Filter" />
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock
                                Margin="0,0,0,2"
                                FontSize="12"
                                Style="{StaticResource FieldLabel}"
                                Text="Material" />
                            <ComboBox
                                x:Name="MaterialSearchComboBox"
                                Width="120"
                                Height="32"
                                ItemsSource="{Binding MaterialForSearch}"
                                SelectionChanged="Filter" />

                        </StackPanel>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock
                                Margin="0,0,0,2"
                                FontSize="12"
                                Style="{StaticResource FieldLabel}"
                                Text="Status" />
                            <ComboBox
                                x:Name="StatusSearchComboBox"
                                Width="120"
                                Height="32"
                                SelectionChanged="Filter">
                                <ComboBoxItem Content="All" />
                                <ComboBoxItem Content="Pending" />
                                <ComboBoxItem Content="Delivered" />
                            </ComboBox>

                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock
                                Margin="0,0,0,2"
                                FontSize="12"
                                Style="{StaticResource FieldLabel}"
                                Text="From:" />
                            <DatePicker
                                x:Name="FromDatePicker"
                                Width="120"
                                Height="32"
                                SelectedDateChanged="Filter" />
                        </StackPanel>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock
                                Margin="0,0,0,2"
                                FontSize="12"
                                Style="{StaticResource FieldLabel}"
                                Text="To:" />
                            <DatePicker
                                x:Name="ToDatePicker"
                                Width="120"
                                Height="32"
                                SelectedDateChanged="Filter" />
                        </StackPanel>

                        <Button
                            x:Name="ResetBtn"
                            Width="100"
                            Height="32"
                            VerticalAlignment="Center"
                            Click="ResetBtn_Click"
                            Style="{StaticResource ModernButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontAwesome}"
                                    FontSize="14"
                                    Foreground="{StaticResource IconsBrush}"
                                    Text="&#xf2f9;" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Reset" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <DataGrid
                    x:Name="OrdersDataGrid"
                    Grid.Row="2"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    IsReadOnly="True"
                    ItemsSource="{Binding OrdersCollection}"
                    RowHeight="35">

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding OrderNumber}"
                            Header="Order #" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Date, StringFormat=\{0:dd/MM/yyyy\}}"
                            Header="Date" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding MaterialName}"
                            Header="Material Name" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding ElementType}"
                            Header="Element Type" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Category}"
                            Header="Category" />
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding Quantity}"
                            Header="Qty" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding UnitPrice, StringFormat=\{0:N2\}}"
                            Header="Price" />

                        <DataGridTextColumn
                            Width="130"
                            Binding="{Binding Total, StringFormat=\{0:N2\}}"
                            ElementStyle="{StaticResource ValueText}"
                            Header="Total Amount" />

                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Status}"
                            Header="Status" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border
                    Grid.Row="3"
                    Padding="0,10,0,0"
                    Style="{StaticResource ModernBorder}">
                    <DockPanel LastChildFill="False">

                        <StackPanel
                            VerticalAlignment="Center"
                            DockPanel.Dock="Left"
                            Orientation="Horizontal">

                            <TextBlock
                                FontSize="11"
                                Foreground="Gray"
                                Style="{StaticResource FieldLabel}"
                                Text="Items:" />
                            <TextBlock
                                x:Name="ItemsCountText"
                                Margin="0,0,15,0"
                                FontWeight="Bold"
                                Text="0" />

                            <TextBlock
                                FontSize="11"
                                Foreground="Gray"
                                Style="{StaticResource FieldLabel}"
                                Text="Total Cost:" />
                            <TextBlock
                                x:Name="TotalCostText"
                                Margin="0,0,15,0"
                                FontWeight="Bold"
                                Foreground="{StaticResource BtnSecondeBrush}"
                                Text="0.00 EGP" />

                            <TextBlock
                                FontSize="11"
                                Foreground="Gray"
                                Style="{StaticResource FieldLabel}"
                                Text="Pending:" />
                            <TextBlock
                                x:Name="PendingText"
                                FontWeight="Bold"
                                Foreground="OrangeRed"
                                Text="0" />

                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button
                                x:Name="DeliveryMarkBtn"
                                Width="160"
                                Height="38"
                                Margin="5,0"
                                Click="DeliveryMarkBtn_Click"
                                Style="{StaticResource SecondaryButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontAwesome}"
                                        FontSize="16"
                                        Foreground="{StaticResource IconsBrush}"
                                        Text="&#xf058;" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="Black"
                                        Text="Mark Delivered" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="ExportBtn"
                                Width="120"
                                Height="38"
                                Margin="5,0"
                                Click="ExportBtn_Click"
                                Style="{StaticResource ModernButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontAwesome}"
                                        FontSize="16"
                                        Foreground="{StaticResource IconsBrush}"
                                        Text="&#xf56e;" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Export" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="DeleteBtn"
                                Width="110"
                                Height="38"
                                Margin="5,0"
                                Click="DeleteBtn_Click"
                                Style="{StaticResource DangerButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontAwesome}"
                                        FontSize="16"
                                        Foreground="{StaticResource IconsBrush}"
                                        Text="&#xf2ed;" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Delete" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>