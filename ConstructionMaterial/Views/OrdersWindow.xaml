<ui:FluentWindow
    x:Class="ConstructionMaterial.Views.OrdersWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Order Management System"
    Width="960"
    Height="620"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Custom TitleBar  -->
        <ui:TitleBar Title="Order Management System" Grid.Row="0" />

        <Border
            Grid.Row="1"
            Margin="20"
            Style="{StaticResource ModernBorder}">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                    <ui:SymbolIcon
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontSize="24"
                        Foreground="{DynamicResource SystemAccentColorBrush}"
                        Symbol="DocumentBulletList24" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="Order History &amp; Tracking" />
                </StackPanel>

                <!--  Filters Panel  -->
                <ui:Card
                    Grid.Row="1"
                    Margin="0,0,0,15"
                    Padding="15,10">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                Foreground="Gray"
                                Text="Category" />
                            <ComboBox
                                x:Name="CategorySearchComboBox"
                                Width="140"
                                Height="36"
                                ItemsSource="{Binding SearchOptions}"
                                SelectionChanged="Filter" />
                        </StackPanel>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                Foreground="Gray"
                                Text="Material" />
                            <ComboBox
                                x:Name="MaterialSearchComboBox"
                                Width="140"
                                Height="36"
                                ItemsSource="{Binding MaterialForSearch}"
                                SelectionChanged="Filter" />
                        </StackPanel>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                Foreground="Gray"
                                Text="Status" />
                            <ComboBox
                                x:Name="StatusSearchComboBox"
                                Width="120"
                                Height="36"
                                SelectionChanged="Filter">
                                <ComboBoxItem Content="All" IsSelected="True" />
                                <ComboBoxItem Content="Pending" />
                                <ComboBoxItem Content="Delivered" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                Foreground="Gray"
                                Text="From:" />
                            <DatePicker
                                x:Name="FromDatePicker"
                                Width="120"
                                Height="36"
                                SelectedDateChanged="Filter" />
                        </StackPanel>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                Foreground="Gray"
                                Text="To:" />
                            <DatePicker
                                x:Name="ToDatePicker"
                                Width="120"
                                Height="36"
                                SelectedDateChanged="Filter" />
                        </StackPanel>

                        <ui:Button
                            x:Name="ResetBtn"
                            Width="100"
                            Height="36"
                            Margin="5,15,0,0"
                            VerticalAlignment="Bottom"
                            Appearance="Secondary"
                            Click="ResetBtn_Click"
                            Content="Reset"
                            Icon="{ui:SymbolIcon Symbol='ArrowCounterclockwise24'}" />
                    </StackPanel>
                </ui:Card>

                <!--  Orders Grid  -->
                <DataGrid
                    x:Name="OrdersDataGrid"
                    Grid.Row="2"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    IsReadOnly="True"
                    ItemsSource="{Binding OrdersCollection}"
                    RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding OrderNumber}"
                            Header="Order #" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Date, StringFormat=\{0:dd/MM/yyyy\}}"
                            Header="Date" />
                        <DataGridTextColumn
                            Width="2*"
                            Binding="{Binding MaterialName}"
                            Header="Material Name" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding ElementType}"
                            Header="Element Type" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Category}"
                            Header="Category" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding Quantity, StringFormat=\{0:N2\}}"
                            Header="Qty" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding UnitPrice, StringFormat=\{0:N2\}}"
                            Header="Price" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding Total, StringFormat=\{0:N2\}}"
                            Header="Total Amount" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Status}"
                            Header="Status" />
                    </DataGrid.Columns>
                </DataGrid>

                <!--  Footer Summary and Actions  -->
                <Border
                    Grid.Row="3"
                    Margin="0,15,0,0"
                    Padding="0,10,0,0"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0">
                    <DockPanel LastChildFill="False">
                        <StackPanel
                            VerticalAlignment="Center"
                            DockPanel.Dock="Left"
                            Orientation="Horizontal">
                            <TextBlock
                                FontSize="12"
                                Foreground="Gray"
                                Text="Items: " />
                            <TextBlock
                                x:Name="ItemsCountText"
                                Margin="0,0,20,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="0" />

                            <TextBlock
                                FontSize="12"
                                Foreground="Gray"
                                Text="Total Cost: " />
                            <TextBlock
                                x:Name="TotalCostText"
                                Margin="0,0,20,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Foreground="LimeGreen"
                                Text="0.00 EGP" />

                            <TextBlock
                                FontSize="12"
                                Foreground="Gray"
                                Text="Pending: " />
                            <TextBlock
                                x:Name="PendingText"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Foreground="Orange"
                                Text="0" />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <ui:Button
                                x:Name="DeliveryMarkBtn"
                                Width="160"
                                Height="38"
                                Margin="5,0"
                                Appearance="Primary"
                                Click="DeliveryMarkBtn_Click"
                                Content="Mark Delivered"
                                Icon="{ui:SymbolIcon Symbol='CheckmarkCircle24'}" />

                            <ui:Button
                                x:Name="ExportBtn"
                                Width="110"
                                Height="38"
                                Margin="5,0"
                                Appearance="Secondary"
                                Click="ExportBtn_Click"
                                Content="Export"
                                Icon="{ui:SymbolIcon Symbol='ArrowExportUp24'}" />

                            <ui:Button
                                x:Name="DeleteBtn"
                                Width="110"
                                Height="38"
                                Margin="5,0"
                                Appearance="Danger"
                                Click="DeleteBtn_Click"
                                Content="Delete"
                                Icon="{ui:SymbolIcon Symbol='Delete24'}" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>