<Window x:Class="ConstructionMaterial.Views.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConstructionMaterial.Views"
        mc:Ignorable="d"
        Title="OrdersWindow" Height="450" Width="800">



    <Border Margin="20" Style="{StaticResource ModernBorder}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <DataGrid x:Name="OrdersDataGrid" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  ItemsSource="{Binding Orders}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Order #" Binding="{Binding OrderNumber}" Width="80" />
                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=\{0:dd/MM/yyyy\}}" Width="100" />
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" />
                    <DataGridTextColumn Header="Material" Binding="{Binding MaterialName}" Width="*" />
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="50" />
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="50" />
                    <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat=\{0:N2\}}" Width="80" />
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=\{0:N2\}}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Foreground" Value="{StaticResource BtnSecondeBrush}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                </DataGrid.Columns>

            </DataGrid>
        </Grid>
    </Border>
</Window>
