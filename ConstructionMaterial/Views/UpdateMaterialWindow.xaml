<Window
    x:Class="ConstructionMaterial.Views.UpdateMaterialWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Update Material"
    Width="400"
    Height="330"
    Background="{StaticResource MainWindowBrush}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBox">
            <EventSetter Event="TextChanged" Handler="TextBox_TextChanged" />
        </Style>
    </Window.Resources>

    <Border Margin="20" Style="{StaticResource ModernBorder}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" VerticalAlignment="Center" Style="{StaticResource ModernText}" Text="Category:" />
            <ComboBox x:Name="CategoryBox" Grid.Row="0" Grid.Column="1" Margin="5"
                      ItemsSource="{Binding MaterialTypes}" />

            <TextBlock Grid.Row="1" VerticalAlignment="Center" Style="{StaticResource ModernText}" Text="Material Name:" />
            <TextBox x:Name="MaterialNameTxt" Grid.Row="1" Grid.Column="1" Margin="5" />

            <TextBlock Grid.Row="2" VerticalAlignment="Center" Style="{StaticResource ModernText}" Text="Unit:" />
            <ComboBox x:Name="UnitComboBox" Grid.Row="2" Grid.Column="1" Margin="5"
                      ItemsSource="{Binding MaterialUnits}"/>

            <TextBlock Grid.Row="3" VerticalAlignment="Center" Style="{StaticResource ModernText}" Text="Unit Price:" />
            <TextBox x:Name="UnitPriceTxt" Grid.Row="3" Grid.Column="1" Margin="5" />

            <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                <Button Width="100" Margin="10,0" Click="Cancel_Click" Content="Cancel" Style="{StaticResource ModernButton}" />
                <Button x:Name="BtnUpdate" Width="100" Margin="10,0" Click="Update_Click" Content="Update" Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>