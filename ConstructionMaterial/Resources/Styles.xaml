
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore">

    <!--  =========================================================  -->
    <!--  Font Awesome  -->
    <!--  =========================================================  -->

    <FontFamily x:Key="FontAwesome">
        /ConstructionMaterial;component/icons/#Font Awesome 7 Free Solid
    </FontFamily>

    <!--  =========================================================  -->
    <!--  Text Styles  -->
    <!--  =========================================================  -->

    <Style x:Key="ValueText" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource BtnSecondeBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="Margin" Value="0,0,10,0" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SecTextBrush}" />
    </Style>

    <Style x:Key="ModernText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SecTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!--  =========================================================  -->
    <!--  DataGrid  -->
    <!--  =========================================================  -->

    <Style x:Key="DataGridColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource MainBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <!--  =========================================================  -->
    <!--  Cards  -->
    <!--  =========================================================  -->

    <Style x:Key="DashboardCard" TargetType="Border">
        <Setter Property="Width" Value="220" />
        <Setter Property="Height" Value="80" />
        <Setter Property="Margin" Value="10" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource GrayBackBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!--  =========================================================  -->
    <!--  Borders  -->
    <!--  =========================================================  -->

    <Style x:Key="ModernBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SecBrush}" />
        <Setter Property="CornerRadius" Value="12" />

        <Setter Property="Effect">
            <Setter.Value>
                <effects:DropShadowEffect
                    BlurRadius="15"
                    Opacity="0.10"
                    ShadowDepth="2" />
            </Setter.Value>
        </Setter>
    </Style>
    <!--  =========================================================  -->
    <!--  ToolTip  -->
    <!--  =========================================================  -->
    <Style TargetType="ToolTip">
        <Setter Property="FontSize" Value="20" />
    </Style>

    <!--  =========================================================  -->
    <!--  TextBox  -->
    <!--  =========================================================  -->

    <Style TargetType="TextBox">
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="0,5" />
        <Setter Property="Padding" Value="5,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderBrush" Value="{StaticResource GrayBackBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Validation.ErrorTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <DockPanel LastChildFill="True">
                        <TextBlock
                            Margin="5,0,0,0"
                            FontSize="12"
                            Foreground="Red"
                            Text="{Binding ElementName=customAdorner, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}" />
                        <Border
                            x:Name="customAdorner"
                            BorderBrush="Red"
                            BorderThickness="1">
                            <AdornedElementPlaceholder />
                        </Border>
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="4" />
            </Style>
        </Style.Resources>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErroreContent}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  =========================================================  -->
    <!--  Primary Button  -->
    <!--  =========================================================  -->

    <Style x:Key="ModernButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource MainTextBrush}" />
        <Setter Property="Background" Value="{StaticResource MainBrush}" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="15,0" />
        <Setter Property="Margin" Value="5" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <Border
                        x:Name="border"
                        Padding="10,0"
                        Background="{TemplateBinding Background}"
                        CornerRadius="7">

                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MainBrushHover}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5" />
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  =========================================================  -->
    <!--  Secondary Button  -->
    <!--  =========================================================  -->

    <Style
        x:Key="SecondaryButton"
        BasedOn="{StaticResource ModernButton}"
        TargetType="Button">

        <Setter Property="Background" Value="{StaticResource BtnSecondeBrush}" />
    </Style>

    <!--  =========================================================  -->
    <!--  Danger Button  -->
    <!--  =========================================================  -->

    <Style
        x:Key="DangerButton"
        BasedOn="{StaticResource ModernButton}"
        TargetType="Button">

        <Setter Property="Background" Value="{StaticResource BtnDangerBrush}" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <Border
                        x:Name="border"
                        Padding="10,0"
                        Background="{TemplateBinding Background}"
                        CornerRadius="7">

                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="Red" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5" />
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

