<UserControl x:Class="ConstructionMaterial.UserControls.MenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ConstructionMaterial.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="300">
    
    <UserControl.Resources>
        <Style TargetType="MenuItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Foreground" Value="{StaticResource SecTextBrush}"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource IconsBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    
    <StackPanel>
        <Menu>
            <MenuItem Header="File">
                <MenuItem.Icon >
                    <TextBlock 
                            FontFamily="{StaticResource FontAwesome}"
                            Text="&#xf15b;" />
                </MenuItem.Icon>

                <MenuItem Header="Save" Click="Save_Click">
                    <MenuItem.Icon >
                        <TextBlock 
                            FontFamily="{StaticResource FontAwesome}"
                            Text="&#xf0c7;"/>
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Load">
                    <MenuItem.Icon >
                        <TextBlock 
                            FontFamily="{StaticResource FontAwesome}"
                            Text="&#xf0ab;"/>
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="About">
                    <MenuItem.Icon >
                        <TextBlock 
                            FontFamily="{StaticResource FontAwesome}"
                            Text="&#xf05a;"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Exit"></MenuItem>
            </MenuItem>
            
            <MenuItem Header="Help">
                <MenuItem.Icon >
                    <TextBlock 
                            FontFamily="{StaticResource FontAwesome}"
                            Text="&#xf059;"/>
                </MenuItem.Icon>
            </MenuItem>
        </Menu>
    </StackPanel>
</UserControl>
