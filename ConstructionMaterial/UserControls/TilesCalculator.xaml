<UserControl x:Class="ConstructionMaterial.UserControls.TilesCalculator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ConstructionMaterial.UserControls"
             xmlns:viewmodels="clr-namespace:ConstructionMaterial.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="350"
             d:DataContext="{d:DesignInstance Type=viewmodels:TilesCalculationViewModel, IsDesignTimeCreatable=False}">
    <Grid Margin="0,20,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Material Name -->
        <TextBlock Text="Material Name:"
                   Grid.Row="0"
                   Style="{StaticResource FieldLabel}"/>

        <ComboBox Grid.Row="0"
                  Grid.Column="1"
                  x:Name="MaterialComboBox"
                  Height="32"
                  Margin="0,5"
                  DisplayMemberPath="Name"
                  ItemsSource="{Binding MaterialNames}"
                  SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}"/>

        <!-- Room Length -->
        <TextBlock Text="Room Length (m):"
                   Grid.Row="1"
                   Style="{StaticResource FieldLabel}"/>

        <TextBox Grid.Row="1"
                 Grid.Column="1"
                 x:Name="RoomLengthTxt"
                 Style="{StaticResource ModernBox}"
                 Text="{Binding RoomLength, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Room Width -->
        <TextBlock Text="Room Width (m):"
                   Grid.Row="2"
                   Style="{StaticResource FieldLabel}"/>

        <TextBox Grid.Row="2"
                 Grid.Column="1"
                 x:Name="RoomWidthTxt"
                 Style="{StaticResource ModernBox}"
                 Text="{Binding RoomWidth, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Tile Size -->
        <TextBlock Text="Tile Size:"
                   Grid.Row="3"
                   Style="{StaticResource FieldLabel}"/>

        <ComboBox Grid.Row="3"
                  x:Name="TileSizeComboBox"
                  Grid.Column="1"
                  Height="32"
                  Margin="0,5"
                  ItemsSource="{Binding TileSizes}"
                  DisplayMemberPath="Name"
                  SelectedItem="{Binding SelectedTile, Mode=TwoWay}"/>

        <!-- Waste -->
        <TextBlock Text="Waste Percentage (%):"
                   Grid.Row="4"
                   Style="{StaticResource FieldLabel}"/>

        <TextBox Grid.Row="4"
                 Grid.Column="1"
                 x:Name="WasteTxt"
                 Style="{StaticResource ModernBox}"
                 Text="{Binding WastePercentage, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15">

            <Button Content="Calculate"
                    Name="TilesCalculateButton"
                    Command="{Binding CalculateTilesCommand}"
                    Style="{StaticResource ModernButton}"/>

            <Button Content="Create Order"
                    Name="SaveButton4"
                    Command="{Binding SaveTilesCommand}"
                    Style="{StaticResource SecondaryButton}"/>
        </StackPanel>

        <local:CalculationOutput Grid.Row="6" 
                                 Grid.ColumnSpan="2" 
                                 x:Name="OutputTilesControl"
                                 VerticalAlignment="Bottom"
                                 OutputValue="{Binding ResultText}"
                                 OutputLabel="Total Order Value:"/>
    </Grid>
</UserControl>
