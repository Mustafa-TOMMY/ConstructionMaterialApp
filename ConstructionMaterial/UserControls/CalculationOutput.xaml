<UserControl x:Class="ConstructionMaterial.UserControls.CalculationOutput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ConstructionMaterial.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" 
             d:DesignWidth="400">
    
    <StackPanel Background="{StaticResource MainTextBrush}"
                Margin="20">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding OutputLabel,RelativeSource={RelativeSource AncestorType=UserControl}}"
                       x:Name="Output"
                   VerticalAlignment="Center" 
                   FontWeight="SemiBold"/>
            <TextBlock x:Name="TotalOrderValue" 
                   Text="{Binding OutputValue,RelativeSource={RelativeSource AncestorType=UserControl}}" 
                   Margin="10,0" 
                   Foreground="{StaticResource BtnSecondeBrush}" 
                   FontWeight="Bold" 
                   FontSize="20"/>
        </StackPanel>
        <TextBlock Text="Note: The total order volume is calculated assuming 10% waste factor."
               FontSize="10"
               FontStyle="Italic"/>
    </StackPanel>
</UserControl>
