<UserControl x:Class="ConstructionMaterial.UserControls.PaintCalculator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ConstructionMaterial.UserControls"
             xmlns:viewmodels="clr-namespace:ConstructionMaterial.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="350"
             d:DataContext="{d:DesignInstance Type=viewmodels:PaintCalculationViewModel, IsDesignTimeCreatable=False}">
    <Grid Margin="0,20,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Surface Type -->
        <TextBlock Text="Surface Type:"
                   Grid.Row="0"
                   Style="{StaticResource FieldLabel}"/>

        <ComboBox Grid.Row="0"
                  x:Name="SurfaceTypeComboBox"
                  Grid.Column="1"
                  ItemsSource="{Binding SurfaceTypes}"
                  SelectedItem="{Binding SelectedSurfaceType, Mode=TwoWay}"
                  Height="32"
                  Margin="0,5"/>

        <!-- Surface Area -->
        <TextBlock Text="Surface Area (m²):"
                   Grid.Row="1"
                   Style="{StaticResource FieldLabel}"/>

        <TextBox Grid.Row="1"
                 Grid.Column="1"
                 x:Name="SurfaceAreaTxt"
                 Style="{StaticResource ModernBox}"
                 Text="{Binding SurfaceArea, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Number Of Coats -->
        <TextBlock Text="Number Of Coats:"
                   Grid.Row="2"
                   Style="{StaticResource FieldLabel}"/>

        <TextBox Grid.Row="2"
                 Grid.Column="1"
                 Height="32"
                 x:Name="NoOfCoatsTxt"
                 Margin="0,5"
                 Style="{StaticResource ModernBox}"
                 Text="{Binding Coats, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Coverage Rate -->
        <TextBlock Text="Coverage Rate(m²/L):"
                   Grid.Row="3"
                   Style="{StaticResource FieldLabel}"/>

        <TextBox Grid.Row="3"
                 Grid.Column="1"
                 x:Name="CoverageRateTxt"
                 Style="{StaticResource ModernBox}"
                 Text="{Binding CoverageRate, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15">

            <Button Content="Calculate"
                    Name="PaintCalculateButton"
                    Command="{Binding CalculatePaintCommand}"
                    Style="{StaticResource ModernButton}"/>

            <Button Content="Create Order"
                    Name="SaveButton3"
                    Command="{Binding SavePaintCommand}"
                    Style="{StaticResource SecondaryButton}"/>
        </StackPanel>

        <local:CalculationOutput Grid.Row="5" 
                                 Grid.ColumnSpan="2" 
                                 x:Name="OutputPaintControl"
                                 VerticalAlignment="Bottom"
                                 OutputValue="{Binding ResultText}"
                                 OutputLabel="Total Order Value:"/>
    </Grid>
</UserControl>
