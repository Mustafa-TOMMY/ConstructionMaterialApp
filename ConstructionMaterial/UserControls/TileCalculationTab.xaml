<UserControl
    x:Class="ConstructionMaterial.UserControls.TileCalculationTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="350"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock
            Grid.Row="0"
            Style="{StaticResource FieldLabel}"
            Text="Material Name:" />
        <ComboBox
            x:Name="MaterialComboBox"
            Grid.Row="0"
            Grid.Column="1"
            Height="32"
            Margin="0,5"
            DisplayMemberPath="Name"
            ItemsSource="{Binding TileMaterials}"
            SelectedIndex="0" />

        <TextBlock
            Grid.Row="1"
            Style="{StaticResource FieldLabel}"
            Text="Room Length (m):" />
        <TextBox
            x:Name="RoomLengthTxt"
            Grid.Row="1"
            Grid.Column="1"
            Style="{StaticResource ModernBox}"
            TextChanged="TextBox_TextChanged" />

        <TextBlock
            Grid.Row="2"
            Style="{StaticResource FieldLabel}"
            Text="Room Width (m):" />
        <TextBox
            x:Name="RoomWidthTxt"
            Grid.Row="2"
            Grid.Column="1"
            Style="{StaticResource ModernBox}"
            TextChanged="TextBox_TextChanged" />

        <TextBlock
            Grid.Row="3"
            Style="{StaticResource FieldLabel}"
            Text="Tile Size (m²):" />
        <ComboBox
            x:Name="TileSizeComboBox"
            Grid.Row="3"
            Grid.Column="1"
            Height="32"
            Margin="0,5"
            DisplayMemberPath="Name"
            ItemsSource="{Binding TileSizes}"
            SelectedIndex="0" />

        <TextBlock
            Grid.Row="4"
            Style="{StaticResource FieldLabel}"
            Text="Waste Percentage (%):" />
        <TextBox
            x:Name="WasteTxt"
            Grid.Row="4"
            Grid.Column="1"
            Style="{StaticResource ModernBox}"
            Text="10"
            TextChanged="TextBox_TextChanged" />

        <StackPanel
            Grid.Row="5"
            Grid.Column="1"
            Margin="0,15"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="CalculateBtn"
                Margin="5,0"
                Click="TilesTabCalculateButton_Click"
                Style="{StaticResource ModernButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource FontAwesome}"
                        Foreground="{StaticResource IconsBrush}"
                        Text="&#xf1ec;" />
                    <TextBlock VerticalAlignment="Center" Text="Calculate" />
                </StackPanel>
            </Button>

            <Button
                x:Name="SaveBtn"
                Click="TilesTabSaveButton_Click"
                Style="{StaticResource SecondaryButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource FontAwesome}"
                        Foreground="{StaticResource IconsBrush}"
                        Text="&#xf0fe;" />
                    <TextBlock VerticalAlignment="Center" Text="Create Order" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>