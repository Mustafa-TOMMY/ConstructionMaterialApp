<Window x:Class="ConstructionMaterial.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConstructionMaterial"
        xmlns:controls="clr-namespace:ConstructionMaterial.UserControls"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Border Margin="20" Style="{StaticResource ModernBorder}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <controls:MenuBar Grid.Row="0"/>

            <StackPanel Grid.Row="1">
                
            </StackPanel>

            <DockPanel Grid.Row="2" LastChildFill="False">
                <TextBlock Style="{StaticResource ModernText}" DockPanel.Dock="Left">Material Catalog:</TextBlock>
                <Button x:Name="AddMaterial" Click="AddMaterial_Click" Style="{StaticResource ModernButton}" DockPanel.Dock="Right">Add Material</Button>
            </DockPanel>

            <DataGrid x:Name="MyDataGrid"
                      Grid.Row="3"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      ItemsSource="{Binding MaterialCatalog}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" />
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="120" />
                    <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10">
                <Button Style="{StaticResource ModernButton}" 
                        Width="200" 
                        Margin="120 0" 
                        Height="30"
                        Click="Button_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf1ec;" Style="{StaticResource ModernText}"/>
                        <TextBlock Text="Open Calculator" Style="{StaticResource ModernText}" Foreground="White"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ModernButton}" Width="200" Margin="120 0" Height="30">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf0ae;" Style="{StaticResource ModernText}"/>
                        <TextBlock Text="Open Orders" Style="{StaticResource ModernText}" Foreground="White"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <controls:StatusBar Grid.Row="5" Margin="0 10"/>
        </Grid>
    </Border>
</Window>
