<Window x:Class="ConstructionMaterial.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConstructionMaterial"
        xmlns:controls="clr-namespace:ConstructionMaterial.UserControls"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="600" 
        Width="800"
        Background="{StaticResource MainTextBrush}"
        Closing="Window_Closing">
    <Border Margin="20" Style="{StaticResource ModernBorder}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!--<controls:MenuBar Grid.Row="0" x:Name="MenuBarControl"/>-->
            <StackPanel Grid.Row="0">
                <Menu>
                    <MenuItem Header="File">
                        <MenuItem.Icon >
                            <TextBlock 
                        FontFamily="{StaticResource FontAwesome}"
                        Text="&#xf15b;" />
                        </MenuItem.Icon>

                        <MenuItem x:Name="Save" Header="Save" Click="Save_Click">
                            <MenuItem.Icon >
                                <TextBlock 
                        FontFamily="{StaticResource FontAwesome}"
                        Text="&#xf0c7;"/>
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="Load">
                            <MenuItem.Icon >
                                <TextBlock 
                        FontFamily="{StaticResource FontAwesome}"
                        Text="&#xf0ab;"/>
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="About">
                            <MenuItem.Icon >
                                <TextBlock 
                        FontFamily="{StaticResource FontAwesome}"
                        Text="&#xf05a;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Exit" Click="Exit_Click"></MenuItem>
                    </MenuItem>

                    <MenuItem Header="Help">
                        <MenuItem.Icon >
                            <TextBlock 
                        FontFamily="{StaticResource FontAwesome}"
                        Text="&#xf059;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </Menu>
            </StackPanel>

            <StackPanel Grid.Row="1" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center">

                <Border Style="{StaticResource DashboardCard}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="CATALOG" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding MaterialCatalog.Count}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Materials" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCard}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="ORDERS" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Orders.Count}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Pending: 3" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardCard}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="TOTAL SPENT" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalCost}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="This Month" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <DockPanel Grid.Row="2" LastChildFill="False">
                <TextBlock Style="{StaticResource ModernText}" 
                           DockPanel.Dock="Left">Material Catalog:</TextBlock>
                <Button x:Name="AddMaterial" Click="AddMaterial_Click" 
                        Style="{StaticResource ModernButton}" 
                        DockPanel.Dock="Right">Add Material</Button>
                <Button x:Name="DeleteMaterial" Click="DeleteMaterial_Click" 
                        Style="{StaticResource DangerButton}" 
                        DockPanel.Dock="Right">Delete Material</Button>
            </DockPanel>

            <DataGrid x:Name="MyDataGrid" Grid.Row="3"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding MaterialCatalog}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="120" />
                    <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="4" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0 10">
                <Button Style="{StaticResource ModernButton}" 
                        Width="200" 
                        Margin="120 0" 
                        Height="30"
                        Click="Calculator_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf1ec;" Style="{StaticResource ModernText}"/>
                        <TextBlock Text="Open Calculator" Style="{StaticResource ModernText}" Foreground="White"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ModernButton}" 
                        x:Name="OrderWindow"
                        Width="200" 
                        Margin="120 0" 
                        Height="30"
                        Click="OrderWindow_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf0ae;" Style="{StaticResource ModernText}"/>
                        <TextBlock Text="Open Orders" Style="{StaticResource ModernText}" Foreground="White"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <controls:StatusBar Grid.Row="5"
                                x:Name="StatusBarControl" 
                                MaterialsCount="{Binding MaterialCatalog.Count}" 
                                Margin="0 10"/>
        </Grid>
    </Border>
</Window>
