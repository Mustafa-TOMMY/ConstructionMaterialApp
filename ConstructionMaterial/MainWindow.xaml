<ui:FluentWindow
    x:Class="ConstructionMaterial.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ConstructionMaterial.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ConstructionMaterial"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Construction Material App"
    Width="850"
    Height="650"
    Closing="Window_Closing"
    MouseDown="Window_MouseDown"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    mc:Ignorable="d">

    <ui:FluentWindow.Resources>
        <DataTemplate x:Key="ActionDataTemplate">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <ui:Button
                    Command="{Binding Path=DataContext.Materials.UpdateMaterialCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                    CommandParameter="{Binding}"
                    Appearance="Secondary"
                    Padding="8,4"
                    Icon="{ui:SymbolIcon Symbol='Edit20'}"
                    ToolTip="Edit Material" />
                <ui:Button
                    Margin="5,0,0,0"
                    Command="{Binding Path=DataContext.Materials.RemoveMaterialCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                    CommandParameter="{Binding}"
                    Appearance="Danger"
                    Padding="8,4"
                    Icon="{ui:SymbolIcon Symbol='Delete20'}"
                    ToolTip="Delete Material" />
            </StackPanel>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Fluent TitleBar -->
        <ui:TitleBar
            Grid.Row="0"
            Title="Construction Material Management"
            Icon="pack://application:,,,/icons/Font Awesome 7 Free-Solid-900.otf" />

        <!-- Menu Bar -->
        <Menu Grid.Row="1" Margin="10,0,10,10" Background="Transparent">
            <MenuItem Header="File">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="Document24" />
                </MenuItem.Icon>
                <MenuItem x:Name="Save" Click="Save_Click" Header="Save">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Save24" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Load">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="ArrowDownload24" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Click="Exit_Click" Header="Exit">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="SignOut24" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="QuestionCircle24" />
                </MenuItem.Icon>
            </MenuItem>
        </Menu>

        <!-- Dashboard Cards -->
        <UniformGrid
            Grid.Row="2"
            Margin="10,0,10,10"
            Columns="3">
            <ui:Card Margin="5" Padding="15">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="Gray"
                        Text="CATALOG" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <ui:SymbolIcon Symbol="Database24" FontSize="20" Margin="0,0,10,0" Filled="True" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                        <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding Path=Materials.MaterialCatalog.Count}" />
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Center" Text="Materials Available" FontSize="11" Foreground="Gray" />
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="5" Padding="15">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="Gray"
                        Text="ORDERS" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <ui:SymbolIcon Symbol="DocumentBulletList24" FontSize="20" Margin="0,0,10,0" Filled="True" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                        <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding Path=Orders.Count}" />
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Center" Text="Total Pending Orders" FontSize="11" Foreground="Gray" />
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="5" Padding="15">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="Gray"
                        Text="TOTAL SPENT" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                        <ui:SymbolIcon Symbol="Money24" FontSize="20" Margin="0,0,10,0" Filled="True" Foreground="LimeGreen"/>
                        <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding Path=TotalCost}" />
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Center" Text="This Month" FontSize="11" Foreground="Gray" />
                </StackPanel>
            </ui:Card>
        </UniformGrid>

        <!-- Actions Dock -->
        <DockPanel Grid.Row="3" Margin="15,0,15,5" LastChildFill="True">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10" LastChildFill="False">
                <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="Material Catalog:" />
                <ui:Button
                    x:Name="AddMaterial"
                    Click="AddMaterial_Click"
                    DockPanel.Dock="Right"
                    Appearance="Primary"
                    Icon="{ui:SymbolIcon Symbol='Add24'}"
                    Content="Add Material" />
            </DockPanel>

            <!-- Catalog DataGrid -->
            <DataGrid
                x:Name="MyDataGrid"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                IsReadOnly="True"
                ItemsSource="{Binding Path=Materials.MaterialCatalog}"
                SelectedItem="{Binding Path=Materials.SelectedMaterial, Mode=TwoWay}"
                RowHeight="40">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Path=Category}"
                        Header="Category" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding Path=Name}"
                        Header="Name" />
                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding Path=Unit}"
                        Header="Unit" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding Path=UnitPrice, StringFormat=\{0:N2\}}"
                        Header="Price (EGP)" />
                    <DataGridTemplateColumn
                        Width="120"
                        CellTemplate="{StaticResource ActionDataTemplate}"
                        Header="Actions" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Navigation Buttons -->
        <StackPanel
            Grid.Row="4"
            Margin="0,10"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <ui:Button
                Width="220"
                Height="40"
                Margin="15,0"
                Click="Calculator_Click"
                Appearance="Secondary"
                Icon="{ui:SymbolIcon Symbol='Calculator24'}"
                Content="Open Calculator" />
            <ui:Button
                x:Name="OrderWindow"
                Width="220"
                Height="40"
                Margin="15,0"
                Click="OrderWindow_Click"
                Appearance="Secondary"
                Icon="{ui:SymbolIcon Symbol='DocumentBulletList24'}"
                Content="Open Orders" />
        </StackPanel>

        <!-- Custom Status Bar -->
        <controls:StatusBar
            x:Name="StatusBarControl"
            Grid.Row="5"
            Margin="15,5"
            MaterialsCount="{Binding Path=Materials.MaterialCatalog.Count}" />
    </Grid>
</ui:FluentWindow>
